{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["version", "engineMcpMode", "defaultPort", "metaTools", "requiredPlugins", "logicalTools"],
  "properties": {
    "version": { "type": "string" },
    "capturedAt": { "type": "string" },
    "engineMcpMode": { "type": "string" },
    "defaultPort": { "type": "number" },
    "metaTools": {
      "type": "object",
      "required": ["listToolsets", "describeToolset", "callTool"],
      "properties": {
        "listToolsets": { "type": "string" },
        "describeToolset": { "type": "string" },
        "callTool": { "type": "string" }
      }
    },
    "requiredPlugins": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1
    },
    "logicalTools": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["candidates"],
        "properties": {
          "candidates": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "properties": {
                "toolset": { "type": "string" },
                "tool": { "type": "string" },
                "legacyFlat": { "type": "string" },
                "argMap": { "type": "object" }
              }
            }
          }
        }
      }
    },
    "toolsets": { "type": "object" }
  }
}
